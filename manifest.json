{
  "manifest_version": 3,
  "name": "Ollama Page Assistant",
  "version": "1.0.0",
  "description": "Summarize and chat with any web page using a local Ollama instance.",

  "permissions": ["activeTab", "storage", "sidePanel", "tabs"],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },

  "action": {
    "default_title": "Ollama Page Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
